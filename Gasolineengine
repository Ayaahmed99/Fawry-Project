public class GasolineEngine implements Engine {
    private int speed = 0;
 
    @Override
    public int getSpeed() { return speed; }
 
    @Override
    public void increase() { speed++; }
 
    @Override
    public void decrease() { if (speed > 0) speed--; }
 
    @Override
    public String toString() { return "GasolineEngine(speed=" + speed + ")"; }
}
 
