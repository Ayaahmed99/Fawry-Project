public class Car {
 
    private Engine engine;
    private int speed = 0;
 
    public Car(Engine engine) {
        this.engine = engine;
    }
 
    public void start() {
        speed = 0;
        System.out.println("Car started. Engine: " + engine);
    }
 
    public void stop() {
        if (speed != 0) {
            System.out.println("Cannot stop: reduce speed to 0 first.");
            return;
        }
        System.out.println("Car stopped.");
    }
 
    public void accelerate() {
        if (speed >= 200) {
            System.out.println("Already at max speed.");
            return;
        }
        speed += 20;
        engine.increase();
        System.out.println("Accelerated to " + speed + " km/h. Engine: " + engine);
    }
 
    public void brake() {
        if (speed <= 0) {
            System.out.println("Already stopped.");
            return;
        }
        speed -= 20;
        engine.decrease();
        System.out.println("Braked to " + speed + " km/h. Engine: " + engine);
    }
 
    public void replaceEngine(Engine engine) {
        this.engine = engine;
        System.out.println("Engine replaced: " + engine);
    }
}
