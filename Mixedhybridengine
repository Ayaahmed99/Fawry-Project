public class MixedHybridEngine implements Engine {
    private static final int ELECTRIC_THRESHOLD = 50;
 
    private final ElectronicEngine electric = new ElectronicEngine();
    private final GasolineEngine gas = new GasolineEngine();
    private int speed = 0;
 
    private Engine activeEngine() {
        return speed < ELECTRIC_THRESHOLD ? electric : gas;
    }
 
    @Override
    public int getSpeed() { return speed; }
 
    @Override
    public void increase() {
        activeEngine().increase();
        speed++;
    }
 
    @Override
    public void decrease() {
        if (speed > 0) {
            activeEngine().decrease();
            speed--;
        }
    }
 
    @Override
    public String toString() {
        String active = speed < ELECTRIC_THRESHOLD ? "electric" : "gas";
        return "MixedHybridEngine(speed=" + speed + ", active=" + active + ")";
    }
}
